# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Wrangler ──────────────────────────────────────────────────────────────────
.wrangler/
worker/.wrangler/
worker/.dev.vars
worker/wrangler.toml

# ── Auto-generated by setup.sh (contains live Worker URL) ─────────────────────
frontend/config.js

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env*.local
*.secret

# ── Build output ──────────────────────────────────────────────────────────────
dist/
.cache/
*.tsbuildinfo

# ── Temp files created by setup.sh (sed -i.bak) ───────────────────────────────
*.bak

# ── Image export output folders ───────────────────────────────────────────────
receipt-images-*/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
